# Copy this file to .env.local and fill in the values.

# Secret used by Auth.js to encrypt session tokens.
# Generate one with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# Credentials from your Spotify app (https://developer.spotify.com/dashboard).
# Add http://127.0.0.1:3000/api/auth/callback/spotify as a Redirect URI.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
